# データベース
DATABASE_URL=postgresql://user:password@localhost:5432/croco

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT認証
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Stripe（Phase 12 予定）
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS（カンマ区切りで複数指定可）
ALLOWED_ORIGINS=https://crocoweb.jp,https://www.crocoweb.jp

# フロントエンドURL（メールリンクで使用）
FRONTEND_URL=https://crocoweb.jp

# メール送信（Resend）
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@crocoweb.jp

# 管理者メール（カンマ区切りで複数指定可）
ADMIN_EMAILS=admin@ecs.osaka-u.ac.jp

# Web Push（VAPID）
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:noreply@example.com

# PII ハッシュ化ソルト（privacy_purge に必須・dev/prod で別値）
PRIVACY_HASH_SALT=your-privacy-hash-salt

# いいね受信枠（BeReal型）の ON/OFF。β は未設定=false
LIKE_QUOTA_ENABLED=false

# Realtime Broadcast（Phase 0）。dev のみ true・prod は未設定=false
REALTIME_BROADCAST_ENABLED=false
